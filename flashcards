  { unit: "U7", term: "Causes of WWI (M.A.I.N.)", def: "Militarism, Alliances (Triple Entente vs. Central Powers), Imperialism, Nationalism. Triggered by assassination of Archduke Franz Ferdinand (1914)." },
  { unit: "U7", term: "Total War", def: "Mobilization of entire economies/societies for war. Civilians become targets; rationing, propaganda, women in workforce." },
