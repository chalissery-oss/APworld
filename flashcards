  { unit: "U8", term: "Marshall Plan (1948)", def: "US economic aid (~$13B) to rebuild Western Europe, contain communism, and create markets for US goods." },
  { unit: "U8", term: "NATO vs. Warsaw Pact", def: "Cold War military alliances: NATO (US-led, 1949) vs. Warsaw Pact (Soviet-led, 1955). Divided Europe ideologically and militarily." },
