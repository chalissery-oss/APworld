  // UNIT 2: Networks of Exchange (1200-1450)
  { unit: "U2", term: "Silk Roads", def: "Overland Eurasian trade routes revived under the Mongols (Pax Mongolica). Spread luxury goods, technologies, religions, and the Black Death." },
  { unit: "U2", term: "Mongol Empire", def: "Largest contiguous land empire in history, founded by Chinggis Khan. Facilitated Eurasian integration, religious tolerance, and the spread of ideas/disease." },
  { unit: "U2", term: "Indian Ocean Trade", def: "Maritime trade network connecting East Africa, Middle East, India, SE Asia, and China. Used monsoon winds, dhows, and junks. Spread Islam and Swahili culture." },
  { unit: "U2", term: "Swahili City-States", def: "East African coastal trading cities (Kilwa, Mombasa) blending Bantu and Arab cultures. Swahili language is Bantu with Arabic loanwords." },
  { unit: "U2", term: "Trans-Saharan Trade", def: "Caravan trade across the Sahara using camels. Exchanged West African gold and slaves for North African salt and goods. Spread Islam." },
  { unit: "U2", term: "Ibn Battuta", def: "Moroccan Muslim scholar (1304-1369) who traveled across Dar al-Islam, leaving detailed accounts of Mali, India, and China." },
  { unit: "U2", term: "Marco Polo", def: "Venetian traveler whose accounts of Yuan China sparked European interest in Asian goods and routes." },
  { unit: "U2", term: "Bubonic Plague (Black Death)", def: "Pandemic spread along Mongol trade routes 1346-1353. Killed ~1/3 of Europe; weakened feudalism and contributed to labor shortages." },
