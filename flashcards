  { unit: "U4", term: "Casta System", def: "Spanish colonial racial hierarchy: Peninsulares > Creoles > Mestizos > Mulattoes > Indigenous/Africans." },
  { unit: "U4", term: "Joint-Stock Companies", def: "Businesses where investors share risk/profit (e.g., British East India Company, Dutch VOC). Enabled colonial ventures and global trade." },
