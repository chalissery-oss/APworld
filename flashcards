  { unit: "U6", term: "Sepoy Mutiny (1857)", def: "Indian rebellion against British East India Company. Led to direct British rule (the Raj) over India." },
  { unit: "U6", term: "Opium Wars (1839-42, 1856-60)", def: "Britain forced China to legalize opium trade. Treaty of Nanjing ceded Hong Kong; began China's 'century of humiliation.'" },
  { unit: "U6", term: "Taiping Rebellion (1850-64)", def: "Massive Chinese civil war led by Hong Xiuquan (claimed to be Jesus' brother). Killed 20-30 million; weakened the Qing." },
