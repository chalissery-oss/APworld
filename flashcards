<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AP World History Flashcards</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
    min-height: 100vh;
    padding: 20px;
    color: #fff;
  }
  .container { max-width: 800px; margin: 0 auto; }
  h1 {
    text-align: center;
    margin-bottom: 8px;
    font-size: 2rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
  }
  .subtitle {
    text-align: center;
    margin-bottom: 24px;
    opacity: 0.9;
    font-size: 0.95rem;
  }
  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 20px;
  }
  .unit-btn {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    padding: 8px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .unit-btn:hover { background: rgba(255,255,255,0.3); }
  .unit-btn.active { background: #ffd700; color: #1e3c72; font-weight: 600; }
  .progress {
    text-align: center;
    margin-bottom: 16px;
    font-size: 0.95rem;
    opacity: 0.95;
  }
  .flashcard {
    perspective: 1500px;
    height: 380px;
    margin-bottom: 24px;
    cursor: pointer;
  }
  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s;
    transform-style: preserve-3d;
  }
  .flashcard.flipped .card-inner { transform: rotateY(180deg); }
  .card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }
  .card-front {
    background: linear-gradient(135deg, #fff 0%, #f0f4ff 100%);
    color: #1e3c72;
  }
  .card-back {
    background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
    color: #1e3c72;
    transform: rotateY(180deg);
    overflow-y: auto;
  }
  .unit-tag {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(30, 60, 114, 0.15);
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .card-hint {
    position: absolute;
    bottom: 16px;
    right: 20px;
    font-size: 0.75rem;
    opacity: 0.6;
  }
  .term {
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .definition {
    font-size: 1rem;
    line-height: 1.6;
    max-height: 100%;
    overflow-y: auto;
  }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .nav-btn {
    background: #ffd700;
    color: #1e3c72;
    border: none;
    padding: 12px 28px;
    border-radius: 30px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    flex: 1;
    max-width: 200px;
  }
  .nav-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.2); }
  .nav-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .shuffle-btn {
    background: rgba(255,255,255,0.2);
    color: white;
    border: 1px solid rgba(255,255,255,0.4);
  }
  @media (max-width: 600px) {
    h1 { font-size: 1.5rem; }
    .term { font-size: 1.4rem; }
    .definition { font-size: 0.95rem; }
    .flashcard { height: 340px; }
    .card-face { padding: 24px; }
  }
</style>
</head>
<body>
<div class="container">
  <h1>AP World History: Modern</h1>
  <p class="subtitle">Tap card to flip. Use buttons to navigate. Good luck tomorrow!</p>

  <div class="controls" id="unitControls"></div>
  <div class="progress" id="progress">Card 1 of 0</div>

  <div class="flashcard" id="flashcard" onclick="flipCard()">
    <div class="card-inner">
      <div class="card-face card-front">
        <div class="unit-tag" id="unitTagFront"></div>
        <div class="term" id="term"></div>
        <div class="card-hint">tap to flip</div>
      </div>
      <div class="card-face card-back">
        <div class="unit-tag" id="unitTagBack"></div>
        <div class="definition" id="definition"></div>
      </div>
    </div>
  </div>

  <div class="nav">
    <button class="nav-btn" id="prevBtn" onclick="prevCard()">Previous</button>
    <button class="nav-btn shuffle-btn" onclick="shuffleCards()">Shuffle</button>
    <button class="nav-btn" id="nextBtn" onclick="nextCard()">Next</button>
  </div>
</div>

<script>
const allCards = [
  // UNIT 1: The Global Tapestry (1200-1450)
  { unit: "U1", term: "Song Dynasty", def: "Chinese dynasty (960-1279) known for economic prosperity, Neo-Confucianism, gunpowder, the magnetic compass, and a robust civil service exam system. Champa rice from Vietnam fueled population growth." },
  { unit: "U1", term: "Neo-Confucianism", def: "Revival of Confucian thought during Song China that incorporated Buddhist and Daoist ideas. Emphasized filial piety, hierarchy, and education. Spread to Korea, Japan, and Vietnam." },
  { unit: "U1", term: "Foot Binding", def: "Practice in Song China that restricted women's mobility, signaling elite status. Reflected the patriarchal nature of Confucian society." },
  { unit: "U1", term: "Dar al-Islam", def: "The 'House of Islam' — regions where Islam was practiced. Expanded through trade, missionaries (Sufis), and military conquest from 1200-1450." },
