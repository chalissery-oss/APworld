  // UNIT 4: Transoceanic Interconnections (1450-1750)
  { unit: "U4", term: "Columbian Exchange", def: "Transfer of plants, animals, people, and diseases between the Old and New Worlds after 1492. Devastated Indigenous populations via smallpox; introduced potatoes, maize to Eurasia." },
  { unit: "U4", term: "Caravel", def: "Maneuverable Portuguese ship combining lateen and square sails. Enabled Atlantic exploration." },
