  { unit: "U7", term: "United Nations (1945)", def: "International organization replacing League of Nations. Aims to prevent war, promote human rights, with Security Council and General Assembly." },
  { unit: "U7", term: "Armenian Genocide (1915-23)", def: "Ottoman Turkish government killed ~1.5 million Armenians during WWI. Often cited as the first modern genocide." },

