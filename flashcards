  // UNIT 3: Land-Based Empires (1450-1750)
  { unit: "U3", term: "Gunpowder Empires", def: "Ottoman, Safavid, Mughal, Ming/Qing, and Russian empires that used gunpowder weapons to expand and consolidate power." },
  { unit: "U3", term: "Ottoman Empire", def: "Sunni Muslim Turkic empire (1299-1922). Captured Constantinople in 1453. Used devshirme system to recruit Janissaries from Christian boys." },
  { unit: "U3", term: "Safavid Empire", def: "Shia Muslim Persian empire (1501-1736). Used Shi'ism to distinguish itself from Sunni Ottomans, creating lasting Sunni-Shia divisions." },
